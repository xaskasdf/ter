\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Post-training BitNet quantization on a Q8\_0-trained Llama 1B. Argmax flips, 0/5 top-5 overlap, RMSE 2.39 in logit space (range $\sim 19$).}}{4}{table.2}\protected@file@percent }
